# Server
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d

# Clover API
CLOVER_API_BASE=https://sandbox.dev.clover.com
CLOVER_APP_ID=your-clover-app-id
CLOVER_APP_SECRET=your-clover-app-secret
CLOVER_MERCHANT_ID=your-merchant-id
CLOVER_API_TOKEN=your-api-token

# Stripe (for $10/month subscription billing)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PRICE_ID=price_your-stripe-price-id
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Database
DB_PATH=./data/cloverpos.db
